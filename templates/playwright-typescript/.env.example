// Auto-generated by AutoTestGen — .env.example
// Copy this file to .env and fill in real values
// NEVER commit .env to version control

# Application URL for the target environment
BASE_URL=https://your-app-url.com

# OIDC / Ping Authentication
# For SPA / PKCE (oidc-ping-pkce): only CLIENT_ID is needed — no client secret for public clients
OIDC_CLIENT_ID=your-client-id
OIDC_ISSUER_URL=https://your-ping-issuer.com/as

# For confidential clients only (oidc-ping, oidc-standard):
# OIDC_CLIENT_SECRET=your-client-secret

# Test user credentials (use a dedicated test/service account with MFA disabled)
APP_USERNAME=your-test-username
APP_PASSWORD=your-test-password
