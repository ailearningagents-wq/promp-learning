# =============================================================================
# AutoTestGen — Environment Variables Template
# =============================================================================
# 1. Copy this file to ".env" (next to it, same folder).
# 2. Fill in every value below.
# 3. Add ".env" to .gitignore — never commit secrets.
# 4. The master orchestrator's pre-flight loads this file IN MEMORY ONLY.
#    Resolved values are NEVER written back to pipeline.config.json or any
#    file under output/.
# =============================================================================

# --- Project ----------------------------------------------------------------
# "existing"  → merge generated artifacts into EXISTING_PROJECT_PATH
# "new"       → create a new test project at NEW_PROJECT_PATH
PROJECT_MODE=existing
EXISTING_PROJECT_PATH=/absolute/path/to/your/test/project
NEW_PROJECT_PATH=/absolute/path/where/new/project/should/be/created
NEW_PROJECT_TECH_STACK=playwright-typescript
# Allowed: playwright-typescript | playwright-javascript | selenium-java |
#          selenium-dotnet | selenium-js | webdriverio

# --- Application ------------------------------------------------------------
APP_NAME=My Application
APP_BASE_URL=https://your-app-url.com
APP_ENVIRONMENT=uat
# Allowed: dev | uat | staging | prod

# --- Auth (OIDC / Ping) -----------------------------------------------------
AUTH_TYPE=oidc-ping-pkce
# Allowed: oidc-ping-pkce | oidc-ping | oidc-standard | basic | none

OIDC_ISSUER_URL=https://your-ping-issuer.com/as
OIDC_CLIENT_ID=your-public-client-id
OIDC_CLIENT_SECRET=
# Leave OIDC_CLIENT_SECRET empty for PKCE flows. Required for oidc-ping / oidc-standard.

OIDC_PKCE_ENABLED=true
OIDC_REDIRECT_URI=https://your-app-url.com/callback
OIDC_SCOPES=openid profile email

# --- Login Form Selectors ---------------------------------------------------
AUTH_LOGIN_PAGE_TITLE=Sign In
AUTH_USERNAME_SELECTOR=#username
AUTH_PASSWORD_SELECTOR=#password
AUTH_SUBMIT_SELECTOR=#kc-login
AUTH_POST_LOGIN_URL_PATTERN=/dashboard

# --- App Credentials --------------------------------------------------------
APP_USERNAME=your-app-username
APP_PASSWORD=your-app-password
